{
  "name": "tennis-trainings-runden-backend",
  "version": "1.0.0",
  "description": "Backend für Hallenplatz-Training-Verwaltung - AWS Lambda Handlers",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp package.json dist/ && cp package-lock.json dist/ && echo deploy-trigger: $(date +%s) > dist/deploy-trigger.txt",
    "watch": "tsc -w",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "tennis",
    "training",
    "hallenplatz"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-ses": "^3.1014.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.138",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.7.2"
  }
}
